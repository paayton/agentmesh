# AgentMesh M0 环境变量模板
# 用法：cp .env.example .env 后填入真实值。.env 不入库（见 .gitignore）。

# ---------- GrowthBook (L3) ----------
# 生产改为团队内网可达地址，如 http://gb.team.internal:3000
GB_APP_ORIGIN=http://localhost:3000
GB_API_HOST=http://localhost:3100
GB_UI_PORT=3000
GB_API_PORT=3100
# 强随机值：openssl rand -hex 32
GB_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
GB_MONGO_USER=root
GB_MONGO_PASS=CHANGE_ME_strong_password

# ---------- Zot OCI Registry (L2) ----------
REGISTRY_PORT=5000

# ---------- LiteLLM Proxy (L1)：云端多厂商统一路由 ----------
LITELLM_PORT=4000
# 客户端走 proxy 用的内部主密钥：openssl rand -hex 24，前缀 sk-
LITELLM_MASTER_KEY=sk-CHANGE_ME_internal_master_key
# 各厂商密钥：仅存于中台，不下发客户端。用哪家填哪家，留空则该模型不可用
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

# ---------- Langfuse (L4)：团队已部署的现有实例 ----------
# 从 Langfuse 项目设置页获取，指向你现有的实例
LANGFUSE_HOST=https://langfuse.your-team.internal
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# ---------- 中台 (M1 启用) ----------
API_PORT=8000
